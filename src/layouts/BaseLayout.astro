---
import TelemetryHUD from "../components/TelemetryHUD.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const basePath = "/AI-Tadpole-OS-Marketing";
---

<!doctype html>
<html lang="en" data-theme="zinc">
  <head>
    <meta
      name="google-site-verification"
      content="fZFIBOhQC_xJPk_Vt_iueDPpdufqV8XOqdifUtCu_dk"
    />
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:url"
      content="https://dds-solutions.github.io/AI-Tadpole-OS-Marketing/"
    />
    <link rel="icon" type="image/svg+xml" href={`${basePath}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta name="ai-sovereign-os" content="AI-Tadpole-OS" />
    <meta
      name="ai-intelligence-category"
      content="Local-first multi-agent swarm runtime"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-zinc-950 text-zinc-100 font-inter antialiased selection:bg-emerald-500/30 overflow-x-hidden"
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-white focus:px-4 focus:py-3 focus:text-sm focus:font-bold focus:text-zinc-950"
    >
      Skip to content
    </a>

    <header
      class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-zinc-950/80 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 sm:px-8"
      >
        <a
          href={`${basePath}/`}
          class="flex min-h-11 items-center gap-3 rounded-lg text-zinc-100 outline-offset-4"
          aria-label="AI-Tadpole-OS home"
        >
          <img
            src={`${basePath}/assets/program-logo.png`}
            alt="AI-Tadpole-OS logo"
            class="h-10 w-10 rounded-lg border border-white/10 object-cover"
          />
          <span class="hidden text-sm font-bold tracking-tight sm:block"
            >AI-Tadpole-OS</span
          >
        </a>
        <nav
          class="hidden items-center gap-8 text-xs font-bold uppercase tracking-[0.18em] text-zinc-500 md:flex"
          aria-label="Primary navigation"
        >
          <a class="hover:text-zinc-100" href="#runtime">Runtime</a>
          <a class="hover:text-zinc-100" href="#interface">Interface</a>
          <a class="hover:text-zinc-100" href="#governance">Governance</a>
          <a class="hover:text-zinc-100" href="#roadmap">Roadmap</a>
        </nav>
        <a
          href="https://github.com/DDS-Solutions/AI-TadPole-OS"
          class="inline-flex min-h-11 items-center rounded-lg border border-emerald-400/30 bg-emerald-400/10 px-4 text-xs font-bold uppercase tracking-[0.16em] text-emerald-300 hover:border-emerald-300 hover:bg-emerald-300 hover:text-zinc-950"
        >
          Source
        </a>
      </div>
    </header>

    <div
      class="fixed inset-0 pointer-events-none z-0 overflow-hidden"
      aria-hidden="true"
    >
      <div class="neural-grid"></div>
      <canvas data-cursor-canvas class="absolute inset-0 z-10"></canvas>
    </div>

    <slot />

    <style is:global>
      :root {
        --font-body: "Inter", system-ui, sans-serif;
        --font-mono:
          "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Consolas,
          monospace;
        --zinc-950: #09090b;
        --zinc-900: #18181b;
        --zinc-800: #27272a;
        --zinc-700: #3f3f46;
        --pulse: #22c55e;
      }

      .font-inter {
        font-family: var(--font-body);
      }
      .font-mono {
        font-family: var(--font-mono);
      }

      h1,
      h2,
      h3,
      .text-display {
        font-family: var(--font-body);
        letter-spacing: 0;
        text-wrap: balance;
      }

      p,
      li {
        text-wrap: pretty;
      }

      .neural-grid {
        position: absolute;
        inset: 0;
        opacity: 0.1;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.032) 1px, transparent 1px),
          linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.032) 1px,
            transparent 1px
          );
        background-size: 64px 64px;
        mask-image: linear-gradient(to bottom, black, transparent 88%);
      }

      .glass-surface {
        background: color-mix(in srgb, var(--zinc-950) 72%, transparent);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }

      .reveal-on-scroll {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 700ms ease,
          transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reveal-on-scroll.active {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        ::before,
        ::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          scroll-behavior: auto !important;
          transition-duration: 0.001ms !important;
        }

        .reveal-on-scroll {
          opacity: 1;
          transform: none;
        }
      }

      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #27272a;
        border-radius: 8px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3f3f46;
      }
    </style>

    <script is:inline>
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (!prefersReducedMotion) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add("active");
            });
          },
          { threshold: 0.12 },
        );

        document.addEventListener("DOMContentLoaded", () => {
          document.querySelectorAll("[data-reveal]").forEach((el) => {
            el.classList.add("reveal-on-scroll");
            observer.observe(el);
          });
        });

        const canvas = document.querySelector("[data-cursor-canvas]");
        const ctx = canvas?.getContext("2d");
        let mouseX = -1000;
        let mouseY = -1000;
        let targets = [];

        function resizeCanvas() {
          if (!canvas) return;
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }

        function updateTargets() {
          targets = Array.from(
            document.querySelectorAll("a, button, .signal-node"),
          ).map((el) => {
            const rect = el.getBoundingClientRect();
            return {
              x: rect.left + rect.width / 2,
              y: rect.top + rect.height / 2,
            };
          });
        }

        window.addEventListener("resize", resizeCanvas);
        document.addEventListener("mousemove", (event) => {
          mouseX = event.clientX;
          mouseY = event.clientY;
        });

        resizeCanvas();
        updateTargets();
        setInterval(updateTargets, 2500);

        function animateCursorField() {
          if (!ctx || !canvas) return;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          targets.forEach((target) => {
            const dx = target.x - mouseX;
            const dy = target.y - mouseY;
            const distance = Math.sqrt(dx * dx + dy * dy);
            if (distance < 260) {
              ctx.beginPath();
              ctx.moveTo(mouseX, mouseY);
              ctx.lineTo(target.x, target.y);
              ctx.strokeStyle = `rgba(34, 197, 94, ${0.18 * (1 - distance / 260)})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          });
          requestAnimationFrame(animateCursorField);
        }

        animateCursorField();
      }
    </script>
    <TelemetryHUD />
  </body>
</html>
