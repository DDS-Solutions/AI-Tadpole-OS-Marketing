---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = "/AI-Tadpole-OS-Marketing";

const architectureLayers = [
  {
    label: "L1",
    title: "Directive layer",
    detail:
      "Human-authored SOPs in Markdown. Versioned directives serve as the absolute source of truth for agent behavior.",
  },
  {
    label: "L2",
    title: "Orchestration layer",
    detail:
      "Agent 99 coordinates swarm hierarchy, decomposes objectives, and performs Self-Annealing to refine long-term memory.",
  },
  {
    label: "L3",
    title: "Execution layer",
    detail:
      "Rust-native engine and deterministic scripts execute tools in parallel using FuturesUnordered for absolute speed and security.",
  },
];

const interfaceSurfaces = [
  "Operations dashboard with 10Hz Swarm Pulse (MessagePack telemetry) and detachable portals",
  "Model manager with triple-slot routing (Primary, Secondary, Tertiary fallback slots)",
  "Codebase Knowledge Graph HUD with dynamic traversal history and BFS Dependency Pathfinder",
  "Security dashboard featuring the Sapphire Shield and OBLITERATUS Merkle audit trails",
];

const governance = [
  [
    "Hard Privacy gate",
    "Block external cloud traffic entirely when a mission requires 100% air-gapped isolation.",
  ],
  [
    "Sapphire Shield",
    "Mandatory human gating for high-risk tool calls like budget:spend and shell:execute.",
  ],
  [
    "OBLITERATUS Hardening",
    "Audit-verified code paths, zero context decay, and Merkle-proof decision history.",
  ],
  [
    "Secret-aware logs",
    "Real-time token and credential scrubbing before telemetry reaches LanceDB storage.",
  ],
];

const roadmap = [
  [
    "Phase 1: Core Engine & Memory",
    "High-Performance Rust Backend (Axum/Tokio), Local-First Memory (LanceDB with text-embedding-004), Reactive Swarm Telemetry & Agent Management UI, Modular Skills (MCP support), and Voice STT/TTS (Piper). [100% Completed]",
  ],
  [
    "Phase 2: Swarm Governance",
    "Intelligent Model Registry (ollama/openai/groq/google/etc), Continuity Scheduler for background executions, Unified Oversight Gate (WebSocket HITL with agent-specific RBAC), GraphRAG entity-relation retrieval, and Swarm Memory Deduplication. [100% Completed]",
  ],
  [
    "Phase 3: Swarm Observability",
    "Advanced Swarm Observability (Observe-Call-Audit tracing), Swarm Collaboration Infrastructure (persistent directives & peer audits), Global Swarm Memory (Vault), and Self-Annealing/Autonomous Skill Synthesis. [100% Completed]",
  ],
  [
    "Phase 4: Swarm Evolution",
    "Global Intelligence Loop (automated Vault retrieval), Autonomous Tool Refinement (self-patching skills), Dynamic Skill Registry hot-reloading without restarts, and Evolution telemetry. [100% Completed]",
  ],
  [
    "Phase 5: Resilient Security",
    "Secret-Aware Telemetry, RFC 9457 compliant Granular Backend Errors, Automated X-Request-Id Trace Correlation, Strict TypeScript Hardening (95%+), and Active Documentation Guard (ADG-01) static analysis release gate. [100% Completed]",
  ],
  [
    "Phase 6: Digital Twin (Current)",
    "Sovereign Process Digital Twin. Query blueprints (Relational DB, REST, Webhooks, Log Scanners, Serial Device modbus), passive Mirror Mode with drift alerts, State Snapshot sandboxed simulations, KPI telemetry dashboards, and ISO/GxP regulatory compliance packages. [In Progress]",
  ],
  [
    "Future Vision",
    "Hardware-Agnostic acceleration (NVIDIA/ARM/RISC-V), Tadpole Hub decentralized templates registry, deep web research clusters, local ONNX embedding engine, and Universal Ingestion (MarkItDown). [Planned]",
  ],
];

const screenshots = [
  {
    src: `${basePath}/assets/real_os_dashboard.png`,
    alt: "AI-Tadpole-OS operations dashboard",
  },
  {
    src: `${basePath}/assets/real_os_nodes.png`,
    alt: "AI-Tadpole-OS node hierarchy interface",
  },
  {
    src: `${basePath}/assets/real_os_oversight.png`,
    alt: "AI-Tadpole-OS oversight and security interface",
  },
];
---

<BaseLayout
  title="AI-Tadpole-OS | Local-First Multi-Agent Swarm Runtime"
  description=" AI-Tadpole-OS is a local-first Rust and React runtime for sovereign multi-agent orchestration, live telemetry, model routing, and human-governed execution."
>
  <main id="main" class="relative z-10">
    <section
      class="relative min-h-[88vh] overflow-hidden border-b border-white/10 pt-28"
    >
      <img
        src={`${basePath}/assets/real_os_dashboard.png`}
        alt=""
        class="absolute inset-0 h-full w-full object-cover opacity-24"
        loading="eager"
      />
      <div
        class="absolute inset-0 bg-[linear-gradient(90deg,#09090b_0%,rgba(9,9,11,0.92)_42%,rgba(9,9,11,0.62)_100%)]"
      >
      </div>
      <div
        class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-zinc-950 to-transparent"
      >
      </div>

      <div
        class="relative mx-auto flex min-h-[calc(88vh-7rem)] max-w-7xl flex-col justify-end px-5 pb-16 sm:px-8 lg:pb-20"
      >
        <div class="max-w-4xl space-y-8">
          <div
            class="inline-flex min-h-11 items-center gap-3 rounded-lg border border-emerald-400/20 bg-zinc-950/70 px-4 font-mono text-[11px] font-bold uppercase tracking-[0.22em] text-emerald-300 backdrop-blur"
          >
            <span class="signal-node h-2 w-2 rounded-full bg-emerald-400"
            ></span>
            Local-first autonomous runtime
          </div>

          <div class="space-y-5">
            <h1
              class="text-display text-6xl font-extrabold leading-[0.92] text-white sm:text-7xl lg:text-6xl"
            >
              AI-Tadpole-OS
            </h1>
            <p
              class="max-w-3xl text-xl leading-8 text-zinc-300 sm:text-2xl sm:leading-9"
            >
              A sovereign command layer for multi-agent work: Rust execution,
              React observability, private memory, and human-governed automation
              in one local runtime.
            </p>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href="https://github.com/DDS-Solutions/AI-TadPole-OS"
              class="inline-flex min-h-12 items-center justify-center rounded-lg bg-white px-6 text-sm font-bold text-zinc-950 hover:bg-zinc-200 transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_25px_rgba(255,255,255,0.25)]"
            >
              Explore the source
            </a>
            <a
              href="#runtime"
              class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 bg-white/5 px-6 text-sm font-bold text-zinc-100 hover:border-emerald-300/50 hover:text-emerald-200 transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_20px_rgba(52,211,153,0.15)]"
            >
              See the architecture
            </a>
          </div>
        </div>
      </div>
    </section>

    <section
      id="runtime"
      class="mx-auto grid max-w-7xl gap-12 px-5 py-24 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:py-32"
      data-reveal
    >
      <div class="space-y-5">
        <p
          class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
        >
          Runtime model
        </p>
        <h2 class="text-4xl font-bold leading-tight text-white sm:text-5xl">
          Built to keep strategy close to the machine.
        </h2>
        <p class="text-lg leading-8 text-zinc-400">
          AI-Tadpole-OS treats a clone as the unit of sovereignty. Directives,
          orchestration, and execution remain inspectable so teams can run
          missions without surrendering operational context to a hosted black
          box.
        </p>
      </div>

      <div class="grid gap-4">
        {
          architectureLayers.map((layer) => (
            <article class="grid gap-5 rounded-lg border border-white/10 bg-zinc-900/40 p-6 sm:grid-cols-[5rem_1fr]">
              <div class="font-mono text-3xl font-bold text-emerald-300">
                {layer.label}
              </div>
              <div class="space-y-2">
                <h3 class="text-2xl font-bold text-white">{layer.title}</h3>
                <p class="leading-7 text-zinc-400">{layer.detail}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section
      id="interface"
      class="border-y border-white/10 bg-zinc-900/20"
      data-reveal
    >
      <div
        class="mx-auto grid max-w-7xl gap-12 px-5 py-24 sm:px-8 lg:grid-cols-[1.2fr_0.8fr] lg:py-32"
      >
        <div class="space-y-5">
          <p
            class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
          >
            Operator interface
          </p>
          <h2 class="text-4xl font-bold leading-tight text-white sm:text-5xl">
            Dense control surfaces for live swarm work.
          </h2>
          <p class="text-lg leading-8 text-zinc-400">
            The product codebase exposes a high-density dashboard system rather
            than a chat-only wrapper. Operators can inspect agents, model slots,
            quotas, telemetry, mission state, and detached tactical views from
            the same shell.
          </p>

          <ul class="grid gap-3 pt-4">
            {
              interfaceSurfaces.map((item) => (
                <li class="flex gap-3 rounded-lg border border-white/10 bg-zinc-950/40 p-4 text-zinc-300">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-400" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="grid gap-4">
          {
            screenshots.map((shot, index) => (
              <figure
                class={`overflow-hidden rounded-lg border border-white/10 bg-zinc-950 ${index === 1 ? "lg:-ml-12" : ""}`}
              >
                <img
                  src={shot.src}
                  alt={shot.alt}
                  class="aspect-[16/9] w-full object-cover"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-5 py-24 sm:px-8 lg:py-32" data-reveal>
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="space-y-5">
          <p
            class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
          >
            Model intelligence
          </p>
          <h2 class="text-4xl font-bold leading-tight text-white sm:text-5xl">
            Provider choice without operational drift.
          </h2>
          <p class="text-lg leading-8 text-zinc-400">
            The model manager is designed around capability-aware routing:
            local/self-hosted models, hosted providers, secure vault sync,
            modality filters, and triple-slot fallback per agent.
          </p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div class="rounded-lg border border-white/10 bg-zinc-900/40 p-6">
            <p
              class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-zinc-500"
            >
              Providers
            </p>
            <h3 class="mt-4 text-2xl font-bold text-white">
              Ollama, OpenAI, Groq, Google, and custom nodes
            </h3>
          </div>
          <div class="rounded-lg border border-white/10 bg-zinc-900/40 p-6">
            <p
              class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-zinc-500"
            >
              Routing
            </p>
            <h3 class="mt-4 text-2xl font-bold text-white">
              Primary, secondary, and tertiary model slots per agent
            </h3>
          </div>
          <div
            class="rounded-lg border border-white/10 bg-zinc-900/40 p-6 sm:col-span-2"
          >
            <img
              src={`${basePath}/assets/real_os_templates.png`}
              alt="AI-Tadpole-OS template and model surfaces"
              class="mb-6 aspect-[16/7] w-full rounded-lg border border-white/10 object-cover"
              loading="lazy"
            />
            <p class="text-zinc-400">
              Industry templates and MCP skills are first-class operational
              material, not marketing add-ons. They feed directly into the
              agent, workflow, and capability model.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section
      id="governance"
      class="border-y border-white/10 bg-zinc-900/20"
      data-reveal
    >
      <div
        class="mx-auto grid max-w-7xl gap-12 px-5 py-24 sm:px-8 lg:grid-cols-[1fr_1fr] lg:py-32"
      >
        <div class="space-y-6">
          <p
            class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
          >
            Governance
          </p>
          <h2 class="text-4xl font-bold leading-tight text-white sm:text-5xl">
            Autonomy with explicit control points.
          </h2>
          <p class="text-lg leading-8 text-zinc-400">
            AI-Tadpole-OS is built around bounded execution. Sensitive actions
            can require human approval, mission spending is visible, and
            local-first operation can be enforced when privacy is the priority.
          </p>
          <img
            src={`${basePath}/assets/real_os_oversight.png`}
            alt="AI-Tadpole-OS security and oversight dashboard"
            class="rounded-lg border border-white/10"
            loading="lazy"
          />
        </div>

        <div class="grid content-start gap-4">
          {
            governance.map(([title, detail]) => (
              <article class="rounded-lg border border-white/10 bg-zinc-950/50 p-6">
                <h3 class="text-xl font-bold text-white">{title}</h3>
                <p class="mt-3 leading-7 text-zinc-400">{detail}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="templates"
      class="mx-auto max-w-7xl px-5 py-24 sm:px-8 lg:py-32 border-b border-white/10"
      data-reveal
    >
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="space-y-6">
          <p
            class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
          >
            Template Ecosystem
          </p>
          <h2
            class="text-4xl font-bold leading-tight text-white sm:text-5xl font-outfit"
          >
            Instantly deploy pre-configured Swarms.
          </h2>
          <p class="text-lg leading-8 text-zinc-400 font-light font-inter">
            Rather than configuring agent swarms from scratch, you can deploy
            official, schema-verified templates across <strong
              >23 distinct industry sectors</strong
            >. Configure roles, playbooks, and operations in minutes.
          </p>

          <div class="flex flex-col gap-3 sm:flex-row pt-2 pb-4">
            <a
              href="https://dds-solutions.github.io/AI-Tadpole-OS-Industry-Templates/"
              class="inline-flex min-h-12 items-center justify-center rounded-lg bg-emerald-400 px-6 text-sm font-bold text-zinc-950 hover:bg-white transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_25px_rgba(52,211,153,0.35)]"
              id="cta-swarm-architect"
            >
              Launch Swarm Architect
            </a>
            <a
              href="https://github.com/DDS-Solutions/AI-Tadpole-OS-Industry-Templates"
              class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 bg-white/5 px-6 text-sm font-bold text-zinc-100 hover:border-emerald-300/50 hover:text-emerald-200 transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_20px_rgba(52,211,153,0.15)]"
              id="cta-template-registry"
            >
              Explore Template Registry
            </a>
          </div>

          <div class="space-y-6 pt-4">
            <div class="flex gap-4 items-start">
              <span class="text-2xl mt-1">🛠️</span>
              <div>
                <h4 class="font-bold text-white text-lg font-outfit">
                  Visual Swarm Architect
                </h4>
                <p
                  class="text-sm text-zinc-400 mt-1 font-light leading-relaxed"
                >
                  A visual drag-and-drop tool to model agent roster hierarchy,
                  map custom missions, and export ready-to-run Swarm archives in
                  one click.
                </p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <span class="text-2xl mt-1">🧠</span>
              <div>
                <h4 class="font-bold text-white text-lg font-outfit">
                  Institutional Knowledge Store (IKS)
                </h4>
                <p
                  class="text-sm text-zinc-400 mt-1 font-light leading-relaxed"
                >
                  Directly ingest company SOPs, manuals, and Confluence
                  playbooks via Markdown YAML frontmatter or JSON indexes
                  straight into your local vector database.
                </p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <span class="text-2xl mt-1">🛡️</span>
              <div>
                <h4 class="font-bold text-white text-lg font-outfit">
                  The Sapphire Shield
                </h4>
                <p
                  class="text-sm text-zinc-400 mt-1 font-light leading-relaxed"
                >
                  Zero-trust execution boundaries. Swarms requesting advanced
                  access (like shell commands or budget execution) are frozen
                  until manual approval is signed by the Overlord.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid gap-6">
          <div
            class="glass-surface p-8 rounded-3xl border border-white/5 space-y-6 bg-gradient-to-b from-white/[0.01] to-transparent"
          >
            <h3
              class="text-xl font-bold text-emerald-400 uppercase tracking-wider font-mono text-center"
            >
              Specialized Swarm Categories
            </h3>

            <div class="grid gap-4 sm:grid-cols-2">
              <div
                class="p-6 bg-black/40 rounded-2xl border border-white/5 space-y-3"
              >
                <div class="text-2xl text-emerald-300">📄 Knowledge Work</div>
                <p class="text-xs text-zinc-400 font-light leading-relaxed">
                  Engineered for research analysis, precedent synthesis,
                  clinical guidelines indexing, tax law mapping, and expert
                  knowledge harvesting.
                </p>
              </div>
              <div
                class="p-6 bg-black/40 rounded-2xl border border-white/5 space-y-3"
              >
                <div class="text-2xl text-emerald-300">⚙️ Edge Operations</div>
                <p class="text-xs text-zinc-400 font-light leading-relaxed">
                  Engineered for shipping & receiving audits, physical inventory
                  tracking, contractor SLA compliance reviews, and ISO 9000
                  quality assurance.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-white/5 space-y-3">
              <p
                class="text-xs font-mono uppercase text-zinc-500 tracking-wider text-center"
              >
                Supported Sectors Include
              </p>
              <div class="flex flex-wrap justify-center gap-2">
                {
                  [
                    "Legal Services",
                    "Medical Practices",
                    "Financial Services",
                    "Digital Marketing",
                    "Manufacturing",
                    "E-commerce",
                    "Real Estate",
                    "Logistics",
                    "Software Dev",
                  ].map((sector) => (
                    <span class="px-3 py-1 rounded-full bg-zinc-900 border border-white/5 text-[10px] text-zinc-300 font-mono">
                      {sector}
                    </span>
                  ))
                }
                <span
                  class="px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-[10px] text-emerald-300 font-mono"
                >
                  +14 More
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="roadmap"
      class="mx-auto max-w-7xl px-5 py-24 sm:px-8 lg:py-32"
      data-reveal
    >
      <div class="mb-12 max-w-3xl space-y-5">
        <p
          class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
        >
          Roadmap
        </p>
        <h2 class="text-4xl font-bold leading-tight text-white sm:text-5xl">
          From local engine to distributed swarm mesh.
        </h2>
        <p class="text-lg leading-8 text-zinc-400">
          The June 5, 2026 product roadmap shows the platform moving through
          governance, memory, distributed runtime, and hardened infrastructure
          work.
        </p>
      </div>

      <div class="overflow-hidden rounded-lg border border-white/10">
        {
          roadmap.map(([phase, detail]) => (
            <div class="grid gap-4 border-b border-white/10 bg-zinc-900/30 p-6 last:border-b-0 sm:grid-cols-[10rem_1fr]">
              <p class="font-mono text-xs font-bold uppercase tracking-[0.22em] text-emerald-300">
                {phase}
              </p>
              <p class="text-zinc-300">{detail}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-5 pb-24 sm:px-8 lg:pb-32" data-reveal>
      <div
        class="relative overflow-hidden rounded-lg border border-emerald-400/20 bg-zinc-900/60 p-8 sm:p-12"
      >
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
          <div class="max-w-3xl space-y-4">
            <p
              class="font-mono text-xs font-bold uppercase tracking-[0.24em] text-emerald-300"
            >
              Clone the runtime
            </p>
            <h2
              class="text-4xl font-bold leading-tight sm:text-5xl slow-pulse-text"
            >
              Own the directives, memory, and execution path.
            </h2>
            <p class="text-lg leading-8 text-zinc-400">
              Start from the source repository, review the architecture, then
              run the Rust engine and React dashboard locally.
            </p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
            <a
              href="https://github.com/DDS-Solutions/AI-TadPole-OS"
              class="inline-flex min-h-12 items-center justify-center rounded-lg bg-emerald-300 px-6 text-sm font-bold text-zinc-950 hover:bg-white transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_25px_rgba(16,185,129,0.35)]"
            >
              Open GitHub
            </a>
            <a
              href="https://github.com/DDS-Solutions/AI-TadPole-OS/blob/main/README.md"
              class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-6 text-sm font-bold text-zinc-100 hover:border-white/40 transition-all duration-300 hover:scale-[1.03]"
            >
              Read quick start
            </a>
          </div>
        </div>
      </div>
    </section>

    <footer class="border-t border-white/10 px-5 py-10 text-center sm:px-8">
      <p
        class="font-mono text-[11px] font-bold uppercase tracking-[0.24em] text-zinc-600"
      >
        AI-Tadpole-OS Engine | Sovereign intelligence runtime
      </p>
    </footer>
  </main>

  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "AI-Tadpole-OS",
      "applicationCategory": "AI Operating System",
      "operatingSystem": "Windows, Linux, macOS, local infrastructure",
      "description": "A local-first Rust and React runtime for orchestrating sovereign multi-agent swarms with telemetry, model routing, memory, and human-governed execution.",
      "codeRepository": "https://github.com/DDS-Solutions/AI-TadPole-OS",
      "author": {
        "@type": "Organization",
        "name": "DDS Solutions"
      }
    }
  </script>

  <style>
    .slow-pulse-text {
      color: #ffffff;
      animation: slowPulse 4s ease-in-out infinite;
    }
    @keyframes slowPulse {
      0%,
      100% {
        color: #ffffff;
        text-shadow: 0 0 10px rgba(52, 211, 153, 0);
      }
      50% {
        color: #a7f3d0; /* emerald-200 */
        text-shadow: 0 0 25px rgba(52, 211, 153, 0.6);
      }
    }
  </style>
</BaseLayout>
