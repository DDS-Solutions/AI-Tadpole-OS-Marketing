---
// src/components/TelemetryHUD.astro
---

<div 
  id="telemetry-hud" 
  class="fixed bottom-6 right-6 z-[100] w-72 md:w-80 h-52 flex flex-col glass-surface rounded-xl overflow-hidden border border-emerald-500/20 shadow-[0_0_30px_rgba(16,185,129,0.1)] transition-all duration-1000 translate-y-32 opacity-0 pointer-events-none"
>
  <!-- Scanline Effect Overlay -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03] z-50 bg-[linear-gradient(rgba(16,185,129,0)_50%,rgba(16,185,129,1)_50%),linear-gradient(90deg,rgba(16,185,129,0)_50%,rgba(16,185,129,1)_50%)] bg-[length:4px_4px]"></div>

  <div class="px-4 py-2 bg-emerald-500/5 border-b border-emerald-500/10 flex justify-between items-center relative z-10">
    <div class="flex items-center gap-2">
      <div class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </div>
      <span class="text-[9px] font-mono font-bold text-emerald-400 uppercase tracking-[0.2em]">Sovereign Telemetry</span>
    </div>
    <span class="text-[8px] font-mono text-emerald-500/40 uppercase tracking-widest">Live_v2.0</span>
  </div>
  
  <div id="telemetry-log" class="flex-1 p-4 font-mono text-[10px] text-emerald-400/90 space-y-1.5 overflow-y-auto scrollbar-none relative z-10">
    <!-- Log entries injected via JS -->
  </div>
</div>

<script>
  const logs = [
    "RECURSIVE_SWARM: Spawning sub-agent [Legal_4]...",
    "NEURAL_MEMORY: Syncing LanceDB vector segments...",
    "BUNKER_DISCOVERY: Node [Gamma-9] found via mDNS.",
    "SHIELD: Governance gated (shell:execute) - [AWAITING_ENTITY_0]",
    "RFC_9457: Problem Details reconciled (parity_guard.py)",
    "HATEOAS: State transition [MISSION -> HYPERMEDIA_ACTIVE]",
    "SOVEREIGN_TTS: Piper warmed up. Ready for synthesis.",
    "LATENCY: Engine telemetry sub-ms threshold achieved.",
    "RECONCILE: Zero context decay across recursive clusters.",
    "SWARM_EVOLUTION: Skill registry hot-reload initiated...",
    "AUDIT: AES-256 neural vault integrity verified.",
    "ORCHESTRATOR: Routing model request to [Ollama-Llama3]."
  ];

  function initTelemetry() {
    const hud = document.getElementById('telemetry-hud');
    const logContainer = document.getElementById('telemetry-log');
    if (!hud || !logContainer) return;

    // Reset if already running (for page transitions)
    logContainer.innerHTML = '';
    let logIndex = 0;
    let timeoutId: number | null = null;

    // Show HUD after delay
    setTimeout(() => {
      hud.classList.remove('translate-y-32', 'opacity-0', 'pointer-events-none');
      hud.classList.add('translate-y-0', 'opacity-100');
    }, 1500);

    function addLog() {
      if (!logContainer) return;

      const entry = document.createElement('div');
      entry.className = 'opacity-0 translate-x-2 transition-all duration-400 border-l border-emerald-500/20 pl-2 py-0.5';
      const timestamp = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
      
      entry.innerHTML = `<span class="text-emerald-500/30 text-[8px]">[${timestamp}]</span> <span class="text-emerald-300/80">${logs[logIndex % logs.length]}</span>`;
      
      logContainer.appendChild(entry);
      
      // Animate entry
      requestAnimationFrame(() => {
        setTimeout(() => {
          entry.classList.remove('opacity-0', 'translate-x-2');
          entry.classList.add('opacity-100', 'translate-x-0');
        }, 10);
      });

      // Auto scroll
      logContainer.scrollTop = logContainer.scrollHeight;

      // Limit entries
      if (logContainer.children.length > 25) {
        const firstChild = logContainer.firstChild;
        if (firstChild) logContainer.removeChild(firstChild);
      }

      logIndex++;
      timeoutId = window.setTimeout(addLog, 1500 + Math.random() * 4000);
    }

    // Start logs after HUD starts appearing
    setTimeout(addLog, 2000);
    
    // Cleanup on page hide
    document.addEventListener('astro:before-preparation', () => {
        if (timeoutId) clearTimeout(timeoutId);
    }, { once: true });
  }

  // Support for both initial load and view transitions
  document.addEventListener('DOMContentLoaded', initTelemetry);
  document.addEventListener('astro:page-load', initTelemetry);
</script>

<style>
  #telemetry-log::-webkit-scrollbar {
    display: none;
  }
  #telemetry-log {
    -ms-overflow-style: none;
    scrollbar-width: none;
    mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
  }
</style>
